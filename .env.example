# FlyCal — Environment Variables

# Port exposed by Docker (default: 4444)
FLYCAL_PORT=4444

# Timezone (default: Europe/Paris)
TZ=Europe/Paris

# CORS origins (comma-separated, empty = disabled, only needed for dev)
# CORS_ORIGINS=http://localhost:3000

# Amadeus API (optional, for fallback flight data)
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
